<?xml version="1.0" encoding="UTF-8"?>
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
         xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
         xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

    <!-- Values in invoice are examples values only. -->

    <!-- Version information   &   hardcode  -->
    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
    <cbc:CustomizationID>urn:piaozone.com:ubl-2.1-customizations:v1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:piaozone.com:profile:bill:v1.0</cbc:ProfileID>

    <!-- 发票头信息 -->
    <!--    Invoice Number; This field is generated by system, you can ignore it-->
<!--    <cbc:ID>INV20250147-0090</cbc:ID>-->
    <!--    Invoice Date; This field is generated by system, you can ignore it-->
<!--    <cbc:IssueDate>2026-03-31</cbc:IssueDate>-->
    <!--    截止日期-->
    <cbc:DueDate>2025-08-14</cbc:DueDate>
    <!--    发票类型 -->
    <cbc:InvoiceTypeCode>381</cbc:InvoiceTypeCode>
    <cbc:Note>this is invoice notes for b2b</cbc:Note>
    <cbc:TaxPointDate>2025-09-14</cbc:TaxPointDate>
    <!--    发票货币代码-->
    <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
    <!-- 购买方联系人 -->
    <cbc:BuyerReference>test@buyer.com</cbc:BuyerReference>

    <!-- Reference to original invoice, it is mandatory to be used when InvoiceTypeCode is 381/383 -->
    <cac:BillingReference>
        <cac:InvoiceDocumentReference>
            <!-- Original invoice number -->
            <cbc:ID>INV20260121001</cbc:ID>
            <cbc:IssueDate>2026-01-01</cbc:IssueDate>
        </cac:InvoiceDocumentReference>
    </cac:BillingReference>

    <!-- 销方信息
    最少只需要传这个字段就可以<cbc:ID schemeID="ERP">ORGID001</cbc:ID>，系统可在主数据匹配到对应的数据；
    其他字段也可以传，不会被覆盖；-->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <cac:PartyIdentification>
                <cbc:ID schemeID="ERP">BU-00008</cbc:ID>
            </cac:PartyIdentification>
            <!--企业ID（税号）信息-->
            <cac:PartyIdentification>
                <cbc:ID schemeID="DE:VAT">DE827333365B01</cbc:ID>
            </cac:PartyIdentification>
            <!-- 销方地址信息 -->
            <cac:PostalAddress>
                <cbc:StreetName>Mainstreet 112</cbc:StreetName>
                <cbc:CityName>DE CITY</cbc:CityName>
                <cbc:PostalZone>10001</cbc:PostalZone>
                <cbc:CountrySubentity>DE State</cbc:CountrySubentity>
                <cac:AddressLine>
                    <cbc:Line>Sales department</cbc:Line>
                </cac:AddressLine>
                <cac:Country>
                    <cbc:IdentificationCode>DE</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Kingdee Test Supplier DE</cbc:RegistrationName>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Contact Name</cbc:Name>
                <cbc:Telephone>+48 01 002 03 04</cbc:Telephone>
                <cbc:ElectronicMail>supplierxxxx@xxxx.com</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- 买方信息-->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <!--企业ID（税号）信息-->
            <cac:PartyIdentification>
                <cbc:ID schemeID="DE:VAT">DE559403414101</cbc:ID>
            </cac:PartyIdentification>
            <cac:PostalAddress>
                <cbc:StreetName>Customer Street Name</cbc:StreetName>
                <cbc:CityName>Customer City Name</cbc:CityName>
                <cbc:PostalZone>12345</cbc:PostalZone>
                <cbc:CountrySubentity>DE State</cbc:CountrySubentity>
                <cac:AddressLine>
                    <cbc:Line>DE Sales department</cbc:Line>
                </cac:AddressLine>
                <cac:Country>
                    <cbc:IdentificationCode>DE</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Kingdee Test Buyer DE</cbc:RegistrationName>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Test Customer Name</cbc:Name>
                <cbc:Telephone>+46 73 572 50 32</cbc:Telephone>
                <cbc:ElectronicMail>buyer@xxxx.com</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- 实际收货客户信息 -->
    <cac:BuyerCustomerParty>
        <cac:Party>
            <!--企业ID（税号）信息-->
            <cac:PartyIdentification>
                <cbc:ID schemeID="DE:VAT">DE559403414101</cbc:ID>
            </cac:PartyIdentification>
            <cac:PostalAddress>
                <cbc:StreetName>Buyer Customer Street Name</cbc:StreetName>
                <cbc:CityName>Buyer Customer City Name</cbc:CityName>
                <cbc:PostalZone>123</cbc:PostalZone>
                <cbc:CountrySubentity>Buyer Customer Province/State</cbc:CountrySubentity>
                <cac:AddressLine>
                    <cbc:Line>XXX department</cbc:Line>
                </cac:AddressLine>
                <cac:Country>
                    <cbc:IdentificationCode>DE</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Kingdee Test Buyer EU</cbc:RegistrationName>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Test Buyer Customer Name</cbc:Name>
                <cbc:Telephone>+46 73 572 50 32</cbc:Telephone>
                <cbc:ElectronicMail>buyer@xxxx.com</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:BuyerCustomerParty>

    <!-- 运输发货信息 -->
    <cac:Delivery>
    <!-- 实际签收日期-->
        <cbc:ActualDeliveryDate>2025-01-01</cbc:ActualDeliveryDate>
        <!--送货地址-->
        <cac:DeliveryLocation>
            <cac:Address>
                <cbc:StreetName>Coolsingel Rotterdam 12</cbc:StreetName>
                <cbc:CityName>Rotterdam</cbc:CityName>
                <cbc:PostalZone>7001</cbc:PostalZone>
                <cbc:CountrySubentity>South Holland</cbc:CountrySubentity>
                <cac:AddressLine>
                    <cbc:Line>Delivery department</cbc:Line>
                </cac:AddressLine>
                <cac:Country>
                    <cbc:IdentificationCode>DE</cbc:IdentificationCode>
                </cac:Country>
            </cac:Address>
        </cac:DeliveryLocation>
    </cac:Delivery>

    <!-- 银行账户信息 -->
    <cac:PaymentMeans>
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode> <!-- Bank Transfer -->
        <cac:PayeeFinancialAccount>
            <cbc:ID>DE23400700****787**300</cbc:ID>
            <cbc:Name>XXXXXX (GERMANY) GmbH</cbc:Name>
            <cac:FinancialInstitutionBranch>
                <cbc:ID>DEUTDEDDXXX</cbc:ID>
                <cac:FinancialInstitution>
                    <cbc:Name>Doutache Bank AG</cbc:Name>
                </cac:FinancialInstitution>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>

    <!-- 付款条款 -->
    <cac:PaymentTerms>
        <cbc:Note>10% advance payment by T/T within 3 working days after contract signing, 90% balance before Rotterdam pick up date
        </cbc:Note>
    </cac:PaymentTerms>

    <!--    表头折扣/收费-->
    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
        <cbc:AllowanceChargeReason>Cleaning</cbc:AllowanceChargeReason>
        <cbc:MultiplierFactorNumeric>10</cbc:MultiplierFactorNumeric>
        <cbc:Amount>20</cbc:Amount>
        <cac:TaxCategory>
            <cbc:ID>S</cbc:ID>
            <cbc:Percent>21</cbc:Percent>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
        <!--        <cbc:AllowanceChargeReasonCode>100</cbc:AllowanceChargeReasonCode>-->
        <cbc:AllowanceChargeReason>Discount</cbc:AllowanceChargeReason>
        <cbc:Amount>20</cbc:Amount>
        <cac:TaxCategory>
            <cbc:ID>S</cbc:ID>
            <cbc:Percent>21</cbc:Percent>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <cac:TaxTotal>
        <!-- 总税额=sum(所有商品行税额)-表头折扣税额+表头收费的税额-->
        <cbc:TaxAmount>21</cbc:TaxAmount> <!-- BT-110 -->
    </cac:TaxTotal>

    <!-- 总计 -->
    <cac:LegalMonetaryTotal>
        <!--        所有商品行-折扣+收费的不含税金额的和-->
        <cbc:TaxExclusiveAmount>200.00</cbc:TaxExclusiveAmount>
        <!--        所有含税金额的和-->
        <cbc:TaxInclusiveAmount>221.00</cbc:TaxInclusiveAmount>

    </cac:LegalMonetaryTotal>

    <!-- 商品行项目1 -->
    <cac:InvoiceLine>
        <!--        行号-->
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="H87">20</cbc:InvoicedQuantity>
        <!--        不含税金额（包含折扣和收费）；系统计算补全，可不用传值-->
        <cbc:LineExtensionAmount>100</cbc:LineExtensionAmount>
        <cac:Item>
            <!--            商品名称-->
            <cbc:Name>Item Module 01</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>21</cbc:Percent>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <!--            单价-->
            <cbc:PriceAmount>5</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

    <!-- 商品行项目2 -->
    <cac:InvoiceLine>
        <cbc:ID>2</cbc:ID>
        <cbc:InvoicedQuantity unitCode="H87">10</cbc:InvoicedQuantity>
        <!--        不含税金额（包含折扣和收费）；系统计算补全 不用传值-->
        <cbc:LineExtensionAmount>100</cbc:LineExtensionAmount>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReason>Line discount</cbc:AllowanceChargeReason>
            <cbc:MultiplierFactorNumeric>5</cbc:MultiplierFactorNumeric>
            <cbc:Amount>5</cbc:Amount>
            <cbc:BaseAmount>100</cbc:BaseAmount>
        </cac:AllowanceCharge>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReason>Line charge</cbc:AllowanceChargeReason>
            <cbc:Amount>5</cbc:Amount>
        </cac:AllowanceCharge>
        <cac:Item>
            <cbc:Description>TWMND-72HD590</cbc:Description>
            <cbc:Name>Item01</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>K</cbc:ID>
                <cbc:Percent>0</cbc:Percent>
                <cbc:TaxExemptionReason>Intra-Community supply to Germany, VAT reverse charge applies. Customer's VAT
                    ID: DE123456789.
                </cbc:TaxExemptionReason>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount>10</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>