<?xml version="1.0" encoding="UTF-8"?>
<!-- Hungary Standard HUF Invoice - KDUBL format -->
<!-- InvoiceTypeCode 380 NORMAL, 27% VAT, Domestic buyer -->
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
         xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
         xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2"
         xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
         xmlns:kdubl="urn:piaozone:ExtensionComponent:1.0">

    <ext:UBLExtensions>
        <ext:UBLExtension>
            <ext:ExtensionAgencyName>Piaozone</ext:ExtensionAgencyName>
            <ext:ExtensionContent>
                <kdubl:PiaozoneExtension>
                    <!-- HU: Invoice appearance - how the document is distributed -->
<!--                    <kdubl:InvoiceAppearance>ELECTRONIC</kdubl:InvoiceAppearance>-->
                    <!-- HU: Customer VAT status - determines allowed content and rules -->
<!--                    <kdubl:CustomerVatStatus>PRIVATE_PERSON</kdubl:CustomerVatStatus>-->
                    <!-- HU: Line-level extensions -->
                    <kdubl:LineExtensions>
                        <kdubl:LineExtension>
                            <kdubl:LineID>1</kdubl:LineID>
                            <!-- HU: Whether the unit can be expressed as a natural unit of measurement -->
                            <kdubl:LineExpressionIndicator>true</kdubl:LineExpressionIndicator>
                        </kdubl:LineExtension>
                    </kdubl:LineExtensions>
                </kdubl:PiaozoneExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
    </ext:UBLExtensions>

    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
    <cbc:CustomizationID>urn:piaozone.com:ubl-2.1-customizations:v1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:piaozone.com:profile:bill:v1.0</cbc:ProfileID>

    <!-- Invoice Number -->
<!--    <cbc:ID>HU20260121001</cbc:ID>-->
    <!-- Invoice Issue Date -->
<!--    <cbc:IssueDate>2026-01-21</cbc:IssueDate>-->
<!--    <cbc:IssueTime>00:00:00+01:00</cbc:IssueTime>-->
    <!-- Invoice Type Code: 380 = Standard Invoice -->
    <cbc:InvoiceTypeCode>380</cbc:InvoiceTypeCode>
    <!-- Invoice Document Currency -->
    <cbc:DocumentCurrencyCode>HUF</cbc:DocumentCurrencyCode>
    <!-- Buyer Reference (BT-10): required by PEPPOL-EN16931-R003 -->
    <cbc:BuyerReference>HU-PO-2026-001</cbc:BuyerReference>

    <!-- HU: Invoice type name → InvoiceTypeCode/@name in PUF (same mechanism as SA SubInvoiceTypeCode) -->
<!--    <cac:AdditionalDocumentReference>-->
<!--        <cbc:ID schemeName="InvoiceTag">NORMAL</cbc:ID>-->
<!--        <cbc:DocumentType>SubInvoiceTypeCode</cbc:DocumentType>-->
<!--    </cac:AdditionalDocumentReference>-->
<!--    <cac:AdditionalDocumentReference>-->
<!--        <cbc:ID schemeName="InvoiceTag">quanchun_lei@kingdee.com</cbc:ID>-->
<!--        <cbc:DocumentType>SenderEmail</cbc:DocumentType>-->
<!--    </cac:AdditionalDocumentReference>-->
    <!-- Seller Information -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <cac:PartyIdentification>
                <cbc:ID schemeID="ERP">ORGID001</cbc:ID>
            </cac:PartyIdentification>
<!--            <cac:PostalAddress>-->
<!--                <cbc:StreetName>Supplier street name</cbc:StreetName>-->
<!--                <cbc:CityName>Supplier city name</cbc:CityName>-->
<!--                <cbc:PostalZone>1342</cbc:PostalZone>-->
<!--                <cac:Country>-->
<!--                    <cbc:IdentificationCode>HU</cbc:IdentificationCode>-->
<!--                </cac:Country>-->
<!--            </cac:PostalAddress>-->
<!--            <cac:PartyTaxScheme>-->
<!--                <cbc:CompanyID>HU000000001</cbc:CompanyID>-->
<!--                <cac:TaxScheme>-->
<!--                    <cbc:ID>VAT</cbc:ID>-->
<!--                </cac:TaxScheme>-->
<!--            </cac:PartyTaxScheme>-->
<!--            <cac:PartyLegalEntity>-->
<!--                <cbc:RegistrationName>Supplier Name</cbc:RegistrationName>-->
<!--                &lt;!&ndash; Seller Legal Registration Identifier &ndash;&gt;-->
<!--                <cbc:CompanyID>23542378214</cbc:CompanyID>-->
<!--            </cac:PartyLegalEntity>-->
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- Buyer Information -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <cac:PostalAddress>
                <cac:Country>
                    <cbc:IdentificationCode>HU</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Buyer name</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
        <!--        <cbc:AllowanceChargeReasonCode>CG</cbc:AllowanceChargeReasonCode>-->
        <cbc:AllowanceChargeReason>Cleaning</cbc:AllowanceChargeReason>
        <cbc:MultiplierFactorNumeric>10</cbc:MultiplierFactorNumeric>
        <cbc:Amount currencyID="HUF">20</cbc:Amount>
        <cbc:BaseAmount currencyID="HUF">200</cbc:BaseAmount>
        <cac:TaxCategory>
            <cbc:ID>S</cbc:ID>
            <cbc:Percent>27</cbc:Percent>
            <cac:TaxScheme>
                <cbc:ID>VAT</cbc:ID>
            </cac:TaxScheme>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
        <!--        <cbc:AllowanceChargeReasonCode>100</cbc:AllowanceChargeReasonCode>-->
        <cbc:AllowanceChargeReason>Discount</cbc:AllowanceChargeReason>
        <cbc:Amount currencyID="HUF">20</cbc:Amount>
        <cac:TaxCategory>
            <cbc:ID>S</cbc:ID>
            <cbc:Percent>27</cbc:Percent>
            <cac:TaxScheme>
                <cbc:ID>VAT</cbc:ID>
            </cac:TaxScheme>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <!-- Tax Total: 27% VAT on 5433 HUF = 1467 HUF -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="HUF">1466.91</cbc:TaxAmount>
<!--        <cac:TaxSubtotal>-->
<!--            <cbc:TaxableAmount currencyID="HUF">5433.00</cbc:TaxableAmount>-->
<!--            <cbc:TaxAmount currencyID="HUF">1467.00</cbc:TaxAmount>-->
<!--            <cac:TaxCategory>-->
<!--                <cbc:ID>S</cbc:ID>-->
<!--                <cbc:Percent>27.00</cbc:Percent>-->
<!--                <cac:TaxScheme>-->
<!--                    <cbc:ID>VAT</cbc:ID>-->
<!--                </cac:TaxScheme>-->
<!--            </cac:TaxCategory>-->
<!--        </cac:TaxSubtotal>-->
    </cac:TaxTotal>

    <!-- Invoice Totals -->
    <cac:LegalMonetaryTotal>
<!--        <cbc:LineExtensionAmount currencyID="HUF">5433.00</cbc:LineExtensionAmount>-->
        <cbc:TaxExclusiveAmount currencyID="HUF">5433.00</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="HUF">6899.91</cbc:TaxInclusiveAmount>
<!--        <cbc:PayableAmount currencyID="HUF">6900.00</cbc:PayableAmount>-->
    </cac:LegalMonetaryTotal>

    <!-- Invoice Line 1 -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="EA">1.00</cbc:InvoicedQuantity>
<!--        <cbc:LineExtensionAmount currencyID="HUF">5433.00</cbc:LineExtensionAmount>-->
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReason>Line discount</cbc:AllowanceChargeReason>
            <cbc:MultiplierFactorNumeric>5</cbc:MultiplierFactorNumeric>
            <cbc:Amount currencyID="HUF">5</cbc:Amount>
            <cbc:BaseAmount currencyID="HUF">100</cbc:BaseAmount>
        </cac:AllowanceCharge>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReason>Line charge</cbc:AllowanceChargeReason>
            <cbc:MultiplierFactorNumeric>5</cbc:MultiplierFactorNumeric>
            <cbc:Amount currencyID="HUF">5</cbc:Amount>
            <cbc:BaseAmount currencyID="HUF">100</cbc:BaseAmount>
        </cac:AllowanceCharge>
<!--        <cac:TaxTotal>-->
<!--            <cbc:TaxAmount currencyID="HUF">1467.00</cbc:TaxAmount>-->
<!--        </cac:TaxTotal>-->
        <cac:Item>
            <cbc:Name>Item 1</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>27.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="HUF">5433.00</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>
