<?xml version="1.0" encoding="UTF-8"?>
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
         xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
         xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

    <!-- Values in invoice are examples values only. -->

    <!-- Version information   &   hardcode  -->
    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
    <cbc:CustomizationID>urn:piaozone.com:ubl-2.1-customizations:v1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:piaozone.com:profile:bill:v1.0</cbc:ProfileID>

    <!-- 发票头信息 -->
    <!--    Invoice Number; This field is generated by system, you can ignore it-->
<!--    <cbc:ID>TW20250147-0090</cbc:ID>-->
    <!--    Invoice Date; This field is generated by system, you can ignore it-->
<!--    <cbc:IssueDate>2025-03-31</cbc:IssueDate>-->
    <!--    截止日期-->
    <!--    发票类型 -->
    <cbc:InvoiceTypeCode>380</cbc:InvoiceTypeCode>
    <cbc:Note>This is invoice notes</cbc:Note>
    <!--    发票货币代码-->
    <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
    <!--    发票计税货币代码 跨境贸易使用-->
    <cbc:TaxCurrencyCode>MYR</cbc:TaxCurrencyCode>

    <cac:OrderReference>
        <cbc:ID>order id 123</cbc:ID>
    </cac:OrderReference>

    <!-- Reference to original invoice, it is mandatory to be used when InvoiceTypeCode is 381/383 -->
<!--    <cac:BillingReference>-->
<!--        <cac:InvoiceDocumentReference>-->
<!--            &lt;!&ndash; Original invoice number &ndash;&gt;-->
<!--            <cbc:ID>HU20260121001</cbc:ID>-->
<!--            <cbc:UUID>UUID-UUID-UUID-UUID-UUID</cbc:UUID>-->
<!--            <cbc:IssueDate>2026-01-01</cbc:IssueDate>-->
<!--        </cac:InvoiceDocumentReference>-->
<!--    </cac:BillingReference>-->

    <!-- 销方信息
    最少只需要传这个字段就可以<cbc:ID schemeID="ERP">ORGID001</cbc:ID>，系统可在主数据匹配到对应的数据；
    其他字段也可以传，不会被覆盖；-->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <cbc:IndustryClassificationCode name="Other information technology service activities n.e.c.">62099</cbc:IndustryClassificationCode>
            <cac:PartyIdentification>
                <cbc:ID schemeID="ERP">HXB-MY-1112</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyIdentification>
                <cbc:ID schemeID="MY:BRN">202501024926</cbc:ID>
            </cac:PartyIdentification>
            <cac:PostalAddress>
                <cbc:StreetName>Street name</cbc:StreetName>
                <cbc:AdditionalStreetName>299</cbc:AdditionalStreetName>
                <cbc:CityName>Kuala Lumpur</cbc:CityName>
                <cbc:PostalZone>50480</cbc:PostalZone>
                <cbc:CountrySubentity>Terengganu</cbc:CountrySubentity>
                <cbc:CountrySubentityCode>11</cbc:CountrySubentityCode>
                <cac:AddressLine>
                    <cbc:Line>ttt</cbc:Line>
                </cac:AddressLine>
                <cac:Country>
                    <cbc:IdentificationCode>MY</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <cbc:CompanyID>C60131481060</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>SST</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>马来西亚测试企业</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- 买方信息-->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <!--企业ID（税号）信息-->
            <cac:PartyIdentification>
                <cbc:ID schemeID="MY:BRN">9113020381008777VN</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyIdentification>
                <cbc:ID schemeID="MY:TIN">IG60426757060</cbc:ID>
            </cac:PartyIdentification>
            <cac:PostalAddress>
                <cbc:StreetName>Customer Street Name</cbc:StreetName>
                <cbc:CityName>Customer City Name</cbc:CityName>
                <cbc:PostalZone>12345</cbc:PostalZone>
<!--                it should follow https://sdk.myinvois.hasil.gov.my/codes/state-codes/-->
                <cbc:CountrySubentityCode>04</cbc:CountrySubentityCode>
                <cac:AddressLine>
                    <cbc:Line>Sales department</cbc:Line>
                </cac:AddressLine>
                <cac:Country>
                    <cbc:IdentificationCode>MY</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Kingdee Test Buyer MY</cbc:RegistrationName>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Test Customer Name</cbc:Name>
                <cbc:Telephone>233331234124</cbc:Telephone>
                <cbc:ElectronicMail>buyer@xxxx.com</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- 银行账户信息 -->
    <cac:PaymentMeans>
        <cbc:PaymentMeansCode>04</cbc:PaymentMeansCode> <!-- Bank Transfer -->
        <cac:PayeeFinancialAccount>
            <cbc:ID>23400700****787**300</cbc:ID>
            <cbc:Name>XXXXXX (GERMANY) GmbH</cbc:Name>
            <cac:FinancialInstitutionBranch>
                <cbc:ID>XXXDDXXX</cbc:ID>
                <cac:FinancialInstitution>
                    <cbc:Name>XXXXX Bank AG</cbc:Name>
                </cac:FinancialInstitution>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>

    <!-- 付款条款 -->
    <cac:PaymentTerms>
        <cbc:Note>10% advance payment by T/T within 3 working days after contract signing, 90% balance before Rotterdam pick up date
        </cbc:Note>
    </cac:PaymentTerms>

    <!--    表头折扣/收费-->
    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
        <cbc:AllowanceChargeReason>Cleaning</cbc:AllowanceChargeReason>
        <cbc:MultiplierFactorNumeric>10</cbc:MultiplierFactorNumeric>
        <cbc:Amount>20</cbc:Amount>
        <cac:TaxCategory>
            <cbc:ID>01</cbc:ID>
            <cbc:Percent>5</cbc:Percent>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
        <!--        <cbc:AllowanceChargeReasonCode>100</cbc:AllowanceChargeReasonCode>-->
        <cbc:AllowanceChargeReason>Discount</cbc:AllowanceChargeReason>
        <cbc:Amount>20</cbc:Amount>
        <cac:TaxCategory>
            <cbc:ID>01</cbc:ID>
            <cbc:Percent>5</cbc:Percent>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <cac:TaxExchangeRate>
        <cbc:SourceCurrencyCode>EUR</cbc:SourceCurrencyCode>
        <cbc:TargetCurrencyCode>MYR</cbc:TargetCurrencyCode>
        <cbc:CalculationRate>1.16</cbc:CalculationRate>
    </cac:TaxExchangeRate>

    <cac:TaxTotal>
        <!-- 总税额=sum(所有商品行税额)-表头折扣税额+表头收费的税额-->
        <cbc:TaxAmount>5</cbc:TaxAmount> <!-- BT-110 -->
    </cac:TaxTotal>

    <!-- 总计 -->
    <cac:LegalMonetaryTotal>
        <!--        所有商品行-折扣+收费的不含税金额的和-->
        <cbc:TaxExclusiveAmount>200.00</cbc:TaxExclusiveAmount>
        <!--        所有含税金额的和-->
        <cbc:TaxInclusiveAmount>205.00</cbc:TaxInclusiveAmount>

    </cac:LegalMonetaryTotal>

    <!-- 商品行项目1 -->
    <cac:InvoiceLine>
        <!--        行号-->
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="H87">20</cbc:InvoicedQuantity>
        <!--        不含税金额（包含折扣和收费）；系统计算补全，可不用传值-->
        <cbc:LineExtensionAmount>100</cbc:LineExtensionAmount>
        <cac:Item>
            <!--            商品名称-->
            <cbc:Name>Item 01</cbc:Name>
            <cac:CommodityClassification>
                <cbc:ItemClassificationCode listID="CLASS">022</cbc:ItemClassificationCode>
            </cac:CommodityClassification>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>01</cbc:ID>
                <cbc:Percent>5</cbc:Percent>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <!--            单价-->
            <cbc:PriceAmount>5</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

    <!-- 商品行项目2 -->
    <cac:InvoiceLine>
        <cbc:ID>2</cbc:ID>
        <cbc:InvoicedQuantity unitCode="H87">10</cbc:InvoicedQuantity>
        <!--        不含税金额（包含折扣和收费）；系统计算补全 不用传值-->
        <cbc:LineExtensionAmount>100</cbc:LineExtensionAmount>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReason>Line discount</cbc:AllowanceChargeReason>
            <cbc:MultiplierFactorNumeric>5</cbc:MultiplierFactorNumeric>
            <cbc:Amount>5</cbc:Amount>
            <cbc:BaseAmount>100</cbc:BaseAmount>
        </cac:AllowanceCharge>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReason>Line charge</cbc:AllowanceChargeReason>
            <cbc:Amount>5</cbc:Amount>
        </cac:AllowanceCharge>
        <cac:Item>
            <cbc:Name>Item 02</cbc:Name>
            <cac:CommodityClassification>
                <cbc:ItemClassificationCode listID="CLASS">022</cbc:ItemClassificationCode>
            </cac:CommodityClassification>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>E</cbc:ID>
                <cbc:Percent>0</cbc:Percent>
                <cbc:TaxExemptionReason>SST Free charge applies reasons</cbc:TaxExemptionReason>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount>10</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>