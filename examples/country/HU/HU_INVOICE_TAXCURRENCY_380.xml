<?xml version="1.0" encoding="UTF-8"?>
<!-- Hungary Invoice with Foreign Currency (EUR) and Tax Currency (HUF) - KDUBL format -->
<!-- InvoiceTypeCode 380 NORMAL, DocumentCurrency EUR, TaxCurrency HUF -->
<!-- Exchange rate: 1 EUR = 361.67 HUF -->
<!-- Net: 250 EUR / 90417.50 HUF, VAT 27%: 67.50 EUR / 24412.73 HUF, Total: 317.50 EUR / 114830.23 HUF -->
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
         xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
         xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2"
         xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
         xmlns:kdubl="urn:piaozone:ExtensionComponent:1.0">

    <ext:UBLExtensions>
        <ext:UBLExtension>
            <ext:ExtensionAgencyName>Piaozone</ext:ExtensionAgencyName>
            <ext:ExtensionContent>
                <kdubl:PiaozoneExtension>
                    <!-- HU: Invoice appearance -->
                    <!-- HU: 如果没有<kdubl:InvoiceAppearance>，默认ELECTRONIC -->
                    <kdubl:InvoiceAppearance>ELECTRONIC</kdubl:InvoiceAppearance>
                    <!-- HU: Customer VAT status -->
                    <kdubl:CustomerVatStatus>DOMESTIC</kdubl:CustomerVatStatus>

                    <!-- HU: Tax subtotal extensions for tax currency amounts per tax category -->
                    <kdubl:TaxTotalExtensions>
                        <kdubl:TaxTotalExtension>
                            <kdubl:TaxSubtotalExtensions>
                                <kdubl:TaxSubtotalExtension>
                                    <!-- Total amount including tax in document currency (EUR) for S/27% category -->
                                    <kdubl:TaxInclusiveAmount currencyID="EUR">317.50</kdubl:TaxInclusiveAmount>
                                </kdubl:TaxSubtotalExtension>
                            </kdubl:TaxSubtotalExtensions>
                        </kdubl:TaxTotalExtension>
                        <kdubl:TaxTotalExtension>
                            <kdubl:TaxSubtotalExtensions>
                                <kdubl:TaxSubtotalExtension>
                                    <!-- Total amount including tax in tax currency (HUF) for S/27% category -->
                                    <kdubl:TaxInclusiveAmount currencyID="HUF">114830.23</kdubl:TaxInclusiveAmount>
                                </kdubl:TaxSubtotalExtension>
                            </kdubl:TaxSubtotalExtensions>
                        </kdubl:TaxTotalExtension>
                    </kdubl:TaxTotalExtensions>

                    <!-- HU: Tax currency monetary totals (when document currency != tax currency) -->
                    <kdubl:TaxCurrencyLegalMonetaryTotal>
                        <cbc:LineExtensionAmount currencyID="HUF">90417.50</cbc:LineExtensionAmount>
                        <cbc:TaxExclusiveAmount currencyID="HUF">90417.50</cbc:TaxExclusiveAmount>
                        <cbc:TaxInclusiveAmount currencyID="HUF">114830.23</cbc:TaxInclusiveAmount>
                        <!-- <cbc:AllowanceTotalAmount currencyID="HUF">0.00</cbc:AllowanceTotalAmount> -->
                        <!-- <cbc:ChargeTotalAmount currencyID="HUF">0.00</cbc:ChargeTotalAmount> -->
                        <!-- <cbc:PayableRoundingAmount currencyID="HUF">0.00</cbc:PayableRoundingAmount> -->
                        <cbc:PayableAmount currencyID="HUF">114830.23</cbc:PayableAmount>
                    </kdubl:TaxCurrencyLegalMonetaryTotal>

                    <!-- HU: Line-level extensions -->
                    <kdubl:LineExtensions>
                        <kdubl:LineExtension>
                            <kdubl:LineID>1</kdubl:LineID>
                            <!-- Total line amount including tax in document currency (EUR) -->
                            <kdubl:TaxInclusiveLineExtensionAmount currencyID="EUR">317.50</kdubl:TaxInclusiveLineExtensionAmount>
                            <kdubl:LineExpressionIndicator>true</kdubl:LineExpressionIndicator>
                            <!-- Tax currency line amounts -->
                            <!-- Total line amount including tax in tax currency (HUF) -->
                            <kdubl:TaxCurrencyTaxInclusiveLineExtensionAmount currencyID="HUF">114830.23</kdubl:TaxCurrencyTaxInclusiveLineExtensionAmount>
                            <!-- Net line amount in tax currency (HUF) -->
                            <kdubl:TaxCurrencyLineExtensionAmount currencyID="HUF">90417.50</kdubl:TaxCurrencyLineExtensionAmount>

                        </kdubl:LineExtension>
                    </kdubl:LineExtensions>
                </kdubl:PiaozoneExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
    </ext:UBLExtensions>

    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
    <cbc:CustomizationID>urn:piaozone.com:ubl-2.1-customizations:v1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:piaozone.com:profile:bill:v1.0</cbc:ProfileID>

    <!-- Invoice Number -->
    <cbc:ID>HU20260303009</cbc:ID>
    <!-- Invoice Issue Date -->
    <cbc:IssueDate>2026-01-21</cbc:IssueDate>
    <cbc:IssueTime>00:00:00+01:00</cbc:IssueTime>
    <!-- Invoice Type Code: 380 = Standard Invoice -->
    <cbc:InvoiceTypeCode>380</cbc:InvoiceTypeCode>
    <!-- Invoice Document Currency (EUR) -->
    <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
    <!-- Tax Currency Code (HUF) - differs from document currency -->
    <cbc:TaxCurrencyCode>HUF</cbc:TaxCurrencyCode>
    <!-- Buyer Reference (BT-10): required by PEPPOL-EN16931-R003 -->
    <cbc:BuyerReference>HU-PO-2026-004</cbc:BuyerReference>

    <!-- HU: Invoice type name → InvoiceTypeCode/@name in PUF (same mechanism as SA SubInvoiceTypeCode) -->
    <cac:AdditionalDocumentReference>
        <cbc:ID schemeName="InvoiceTag">NORMAL</cbc:ID>
        <cbc:DocumentType>SubInvoiceTypeCode</cbc:DocumentType>
    </cac:AdditionalDocumentReference>
    <cac:AdditionalDocumentReference>
        <cbc:ID schemeName="InvoiceTag">quanchun_lei@kingdee.com</cbc:ID>
        <cbc:DocumentType>SenderEmail</cbc:DocumentType>
    </cac:AdditionalDocumentReference>
    <!-- Seller Information -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <cac:PartyName>
                <cbc:Name>Supplier Name</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:StreetName>Supplier street name</cbc:StreetName>
                <cbc:CityName>Supplier city name</cbc:CityName>
                <cbc:PostalZone>1342</cbc:PostalZone>
                <cac:Country>
                    <cbc:IdentificationCode>HU</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <cbc:CompanyID>30417856-2-51</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Supplier Name</cbc:RegistrationName>
<!--                <cbc:CompanyID>23542378-2-14</cbc:CompanyID>-->
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- Buyer Information -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <cac:PartyIdentification>
                <!-- HU: Buyer group member tax number -->
                <cbc:ID schemeID="HU:GroupAFA">23545565-4-14</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyName>
                <cbc:Name>Buyer name</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:StreetName>Buyer street name</cbc:StreetName>
                <cbc:CityName>Buyer city name</cbc:CityName>
                <cbc:PostalZone>1342</cbc:PostalZone>
                <cac:Country>
                    <cbc:IdentificationCode>HU</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <cbc:CompanyID>23544565-2-14</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Buyer name</cbc:RegistrationName>
                <!-- HU: Buyer main taxpayer number -->
<!--                <cbc:CompanyID schemeID="HU:TaxpayerId">23544565-2-14</cbc:CompanyID>-->
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- Exchange Rate: EUR to HUF, rate 361.67 -->
    <cac:TaxExchangeRate>
        <cbc:SourceCurrencyCode>EUR</cbc:SourceCurrencyCode>
        <cbc:TargetCurrencyCode>HUF</cbc:TargetCurrencyCode>
        <!-- Exchange rate: 1 EUR = 361.67 HUF -->
        <cbc:CalculationRate>361.67</cbc:CalculationRate>
        <cbc:MathematicOperatorCode>Multiply</cbc:MathematicOperatorCode>
        <cbc:Date>2026-01-21</cbc:Date>
    </cac:TaxExchangeRate>

    <!-- Tax Total in document currency (EUR): 27% VAT on 250 EUR = 67.50 EUR -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="EUR">67.50</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="EUR">250.00</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="EUR">67.50</cbc:TaxAmount>
            <cac:TaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>27.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>
    <!-- Tax Total in tax currency (HUF): 24412.73 HUF -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="HUF">24412.73</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="HUF">90417.50</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="HUF">24412.73</cbc:TaxAmount>
            <cac:TaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>27.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <!-- Invoice Totals in document currency (EUR) -->
    <cac:LegalMonetaryTotal>
        <cbc:LineExtensionAmount currencyID="EUR">250.00</cbc:LineExtensionAmount>
        <cbc:TaxExclusiveAmount currencyID="EUR">250.00</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="EUR">317.50</cbc:TaxInclusiveAmount>
        <cbc:PayableAmount currencyID="EUR">317.50</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- Invoice Line 1: 250 EUR with 27% HUF tax -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="EA">1</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="EUR">250.00</cbc:LineExtensionAmount>
        <!-- Line tax in document currency (EUR) -->
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="EUR">67.50</cbc:TaxAmount>
            <cac:TaxSubtotal>
                <cbc:TaxableAmount currencyID="EUR">250.00</cbc:TaxableAmount>
                <cbc:TaxAmount currencyID="EUR">67.50</cbc:TaxAmount>
                <cac:TaxCategory>
                    <cbc:ID>S</cbc:ID>
                    <cbc:Percent>27.00</cbc:Percent>
                    <cac:TaxScheme>
                        <cbc:ID>VAT</cbc:ID>
                    </cac:TaxScheme>
                </cac:TaxCategory>
            </cac:TaxSubtotal>
        </cac:TaxTotal>
        <!-- Line tax in tax currency (HUF) -->
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="HUF">24412.73</cbc:TaxAmount>
            <cac:TaxSubtotal>
                <cbc:TaxableAmount currencyID="HUF">90417.50</cbc:TaxableAmount>
                <cbc:TaxAmount currencyID="HUF">24412.73</cbc:TaxAmount>
                <cac:TaxCategory>
                    <cbc:ID>S</cbc:ID>
                    <cbc:Percent>27.00</cbc:Percent>
                    <cac:TaxScheme>
                        <cbc:ID>VAT</cbc:ID>
                    </cac:TaxScheme>
                </cac:TaxCategory>
            </cac:TaxSubtotal>
        </cac:TaxTotal>
        <cac:Item>
            <cbc:Name>Item 1</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>27.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="EUR">250.00</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>
