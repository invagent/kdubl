<?xml version="1.0" encoding="UTF-8"?>
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
         xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
         xmlns:kdubl="urn:piaozone:ExtensionComponent:1.0"
         xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
         xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

    <!-- ===== KDUBL 扩展：西班牙特有字段 ===== -->
    <ext:UBLExtensions>
        <ext:UBLExtension>
            <ext:ExtensionAgencyName>Piaozone</ext:ExtensionAgencyName>
            <ext:ExtensionContent>
                <kdubl:PiaozoneExtension>
                    <kdubl:TaxSubtotalExtensions>
                        <!-- TaxSubtotal[0]: IVA 21% 普通税制 01 -->
                        <kdubl:TaxSubtotalExtension index="0">
                            <kdubl:TaxRegimeCode>01</kdubl:TaxRegimeCode>
                        </kdubl:TaxSubtotalExtension>
                    </kdubl:TaxSubtotalExtensions>
                </kdubl:PiaozoneExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
    </ext:UBLExtensions>

    <!-- ===== 发票头 ===== -->
    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
    <cbc:CustomizationID>urn:piaozone.com:ubl-2.1-customizations:v1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:piaozone.com:profile:bill:v1.0</cbc:ProfileID>

    <!-- 发票号：对应 SII NumSerieFacturaEmisor=26003407，无系列号前缀 -->
    <cbc:ID>20260513000000003</cbc:ID>
    <!-- 开票日期：SII FechaExpedicionFacturaEmisor=08-05-2026 -->
    <cbc:IssueDate>2026-05-13</cbc:IssueDate>
    <cbc:IssueTime>16:37:00+08:00</cbc:IssueTime>
    <cbc:DueDate>2026-06-11</cbc:DueDate>
    <!-- F1 = 标准发票 -->
    <cbc:InvoiceTypeCode name="F1">380</cbc:InvoiceTypeCode>
    <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>

    <!-- ===== 发票系列号（SII 无系列号，InvoiceTag 留空或省略）===== -->
    <!-- SII NumSerieFacturaEmisor 直接用发票号，不拼系列号 -->

    <!-- ===== 卖方信息（SII Titular/IDEmisorFactura: N0039889A DELUAT）===== -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <cac:PartyName>
                <cbc:Name>DELUAT</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:StreetName>Calle Mayor 1</cbc:StreetName>
                <cbc:CityName>Madrid</cbc:CityName>
                <cbc:PostalZone>28001</cbc:PostalZone>
                <cbc:CountrySubentity>Madrid</cbc:CountrySubentity>
                <cac:Country>
                    <cbc:IdentificationCode>ES</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <cbc:CompanyID>N0039889A</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>DELUAT</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- ===== 买方信息（SII Contraparte: N0039889A CLIENTE TEST）===== -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <cac:PartyName>
                <cbc:Name>CLIENTE TEST</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:StreetName>Avenida Test 1</cbc:StreetName>
                <cbc:CityName>Barcelona</cbc:CityName>
                <cbc:PostalZone>08001</cbc:PostalZone>
                <cbc:CountrySubentity>Barcelona</cbc:CountrySubentity>
                <cac:Country>
                    <cbc:IdentificationCode>ES</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <cbc:CompanyID>B63276174</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>CLIENTE TEST</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- ===== 税务合计（SII: BaseImponible=67.33, TipoImpositivo=21, CuotaRepercutida=14.14）===== -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="EUR">14.14</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="EUR">67.33</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="EUR">14.14</cbc:TaxAmount>
            <cac:TaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>21.0</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <!-- ===== 法定金额合计（67.33 + 14.14 = 81.47）===== -->
    <cac:LegalMonetaryTotal>
        <cbc:LineExtensionAmount currencyID="EUR">67.33</cbc:LineExtensionAmount>
        <cbc:TaxExclusiveAmount currencyID="EUR">67.33</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="EUR">81.47</cbc:TaxInclusiveAmount>
        <cbc:PayableAmount currencyID="EUR">81.47</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- ===== 发票行 ===== -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="PCE">1</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="EUR">67.33</cbc:LineExtensionAmount>
        <cac:Item>
            <!-- SII DescripcionOperacion: Factura cliente -->
            <cbc:Description>Factura cliente</cbc:Description>
            <cbc:Name>Factura cliente</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>21.0</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="EUR">67.33</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>
