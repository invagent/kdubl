<?xml version="1.0" encoding="UTF-8"?>
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
         xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
         xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

    <!-- Denmark (DK) KDUBL Invoice Sample -->
    <!-- Danish VAT (MOMS) standard rate: 25% -->
    <!-- Intra-community supply to EU buyer: K category (zero-rated) -->

    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
    <cbc:CustomizationID>urn:piaozone.com:ubl-2.1-customizations:v1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:piaozone.com:profile:bill:v1.0</cbc:ProfileID>

    <!-- Invoice Number -->
    <cbc:ID>DK20260317001001</cbc:ID>
    <!-- Issue Date -->
    <cbc:IssueDate>2026-03-17</cbc:IssueDate>
    <cbc:IssueTime>09:00:00+01:00</cbc:IssueTime>
    <!-- Due Date -->
    <cbc:DueDate>2026-04-17</cbc:DueDate>
    <!-- Invoice Type: 380 = Commercial invoice -->
    <cbc:InvoiceTypeCode>380</cbc:InvoiceTypeCode>
    <cbc:Note>Faktura / Danish MOMS Invoice</cbc:Note>
    <!-- Currency: DKK -->
    <cbc:DocumentCurrencyCode>DKK</cbc:DocumentCurrencyCode>
    <!-- Buyer Reference -->
    <cbc:BuyerReference>DK-BUYER-REF-001</cbc:BuyerReference>

    <!-- Invoice Period -->
    <cac:InvoicePeriod>
        <cbc:StartDate>2026-03-01</cbc:StartDate>
        <cbc:EndDate>2026-03-31</cbc:EndDate>
    </cac:InvoicePeriod>

    <!-- Order Reference -->
    <cac:OrderReference>
        <cbc:ID>DK-ORDER-20260301</cbc:ID>
    </cac:OrderReference>

    <!-- InvoiceContext -->
    <cac:AdditionalDocumentReference>
        <cbc:ID schemeName="InvoiceTag">NA</cbc:ID>
        <cbc:DocumentType>InvoiceContext</cbc:DocumentType>
    </cac:AdditionalDocumentReference>

    <!-- SelfBilled -->
    <cac:AdditionalDocumentReference>
        <cbc:ID schemeName="InvoiceTag">false</cbc:ID>
        <cbc:DocumentType>SelfBilled</cbc:DocumentType>
    </cac:AdditionalDocumentReference>

    <!-- Attachment -->
    <cac:AdditionalDocumentReference>
        <cbc:ID>DK-DOC-001</cbc:ID>
        <cbc:DocumentDescription>Fakturaspecifikation / Invoice specification</cbc:DocumentDescription>
        <cac:Attachment>
            <cac:ExternalReference>
                <cbc:URI>https://www.example.dk/faktura/spec001.html</cbc:URI>
            </cac:ExternalReference>
        </cac:Attachment>
    </cac:AdditionalDocumentReference>

    <!-- Supplier (Seller) Information -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <cac:PartyName>
                <cbc:Name>Kingdee Danmark ApS</cbc:Name>
            </cac:PartyName>
            <!-- Supplier Address -->
            <cac:PostalAddress>
                <cbc:StreetName>Rådhuspladsen 1</cbc:StreetName>
                <cbc:AdditionalStreetName>4. sal</cbc:AdditionalStreetName>
                <cbc:CityName>København</cbc:CityName>
                <cbc:PostalZone>1550</cbc:PostalZone>
                <cbc:CountrySubentity>Region Hovedstaden</cbc:CountrySubentity>
                <cac:Country>
                    <cbc:IdentificationCode>DK</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <!-- Danish VAT number: DK + CVR number (8 digits) -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>DK12345678</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <!-- CVR: Central Business Register number -->
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Kingdee Danmark ApS</cbc:RegistrationName>
                <cbc:CompanyID schemeID="DK:CVR">12345678</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Lars Hansen</cbc:Name>
                <cbc:Telephone>+45-33-12-34-56</cbc:Telephone>
                <cbc:ElectronicMail>lars.hansen@kingdee.dk</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- Buyer (Customer) Information (EU buyer for intra-community supply) -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <cac:PartyName>
                <cbc:Name>Nordic Trading GmbH</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:StreetName>Vesterbrogade 100</cbc:StreetName>
                <cbc:AdditionalStreetName>2. sal</cbc:AdditionalStreetName>
                <cbc:CityName>Frederiksberg</cbc:CityName>
                <cbc:PostalZone>1620</cbc:PostalZone>
                <cbc:CountrySubentity>Region Syddanmark</cbc:CountrySubentity>
                <cac:Country>
                    <cbc:IdentificationCode>DE</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <!-- German buyer VAT number for intra-community supply -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>DE876543210</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Nordic Trading GmbH</cbc:RegistrationName>
                <cbc:CompanyID schemeID="DE:STNR">DE876543210</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Mette Christensen</cbc:Name>
                <cbc:Telephone>+45-86-98-76-54</cbc:Telephone>
                <cbc:ElectronicMail>mette.christensen@nordictrading.dk</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- Delivery Information -->
    <cac:Delivery>
        <cbc:ActualDeliveryDate>2026-03-15</cbc:ActualDeliveryDate>
        <cac:DeliveryLocation>
            <cac:Address>
                <cbc:StreetName>Åboulevarden 50</cbc:StreetName>
                <cbc:CityName>Aarhus</cbc:CityName>
                <cbc:PostalZone>8000</cbc:PostalZone>
                <cac:Country>
                    <cbc:IdentificationCode>DE</cbc:IdentificationCode>
                </cac:Country>
            </cac:Address>
        </cac:DeliveryLocation>
    </cac:Delivery>

    <!-- Payment Means -->
    <cac:PaymentMeans>
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode> <!-- Bank Transfer -->
        <cac:PayeeFinancialAccount>
            <cbc:ID>DK5000400440116243</cbc:ID>
            <cbc:Name>Kingdee Danmark ApS</cbc:Name>
            <cac:FinancialInstitutionBranch>
                <cbc:ID>DABADKKKXXX</cbc:ID>
                <cac:FinancialInstitution>
                    <cbc:Name>Danske Bank A/S</cbc:Name>
                </cac:FinancialInstitution>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>

    <!-- Payment Terms -->
    <cac:PaymentTerms>
        <cbc:Note>Betalingsbetingelser: netto 30 dage / Net 30 days</cbc:Note>
    </cac:PaymentTerms>

    <!-- Header Charge (Standard rate 25% MOMS) -->
    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
        <cbc:AllowanceChargeReasonCode>CG</cbc:AllowanceChargeReasonCode>
        <cbc:AllowanceChargeReason>Håndteringsgebyr / Handling charge</cbc:AllowanceChargeReason>
        <cbc:MultiplierFactorNumeric>10</cbc:MultiplierFactorNumeric>
        <cbc:Amount currencyID="DKK">150</cbc:Amount>
        <cbc:BaseAmount currencyID="DKK">1500</cbc:BaseAmount>
        <cac:TaxCategory>
            <cbc:ID>S</cbc:ID>
            <cbc:Percent>25</cbc:Percent>
            <cac:TaxScheme>
                <cbc:ID>VAT</cbc:ID>
            </cac:TaxScheme>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <!-- Header Discount (Standard rate 25% MOMS) -->
    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
        <cbc:AllowanceChargeReasonCode>100</cbc:AllowanceChargeReasonCode>
        <cbc:AllowanceChargeReason>Rabat / Discount</cbc:AllowanceChargeReason>
        <cbc:Amount currencyID="DKK">150</cbc:Amount>
        <cac:TaxCategory>
            <cbc:ID>S</cbc:ID>
            <cbc:Percent>25</cbc:Percent>
            <cac:TaxScheme>
                <cbc:ID>VAT</cbc:ID>
            </cac:TaxScheme>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <!-- Tax Total -->
    <cac:TaxTotal>
        <!-- Total VAT = sum(line VAT) - header discount VAT + header charge VAT -->
        <cbc:TaxAmount currencyID="DKK">375</cbc:TaxAmount> <!-- BT-110 -->
        <!-- Standard rate 25% MOMS -->
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="DKK">1500</cbc:TaxableAmount> <!-- BT-116 -->
            <cbc:TaxAmount currencyID="DKK">375</cbc:TaxAmount> <!-- BT-117 -->
            <cac:TaxCategory>
                <cbc:ID>S</cbc:ID> <!-- BT-118 Standard rated -->
                <cbc:Percent>25</cbc:Percent> <!-- BT-119 Danish MOMS standard rate -->
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
        <!-- Intra-community supply K at 0% -->
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="DKK">1500</cbc:TaxableAmount> <!-- BT-116 -->
            <cbc:TaxAmount currencyID="DKK">0</cbc:TaxAmount> <!-- BT-117 -->
            <cac:TaxCategory>
                <cbc:ID>K</cbc:ID> <!-- BT-118 Intra-community supply -->
                <cbc:Percent>0</cbc:Percent> <!-- BT-119 -->
                <cbc:TaxExemptionReasonCode>VATEX-EU-IC</cbc:TaxExemptionReasonCode>
                <cbc:TaxExemptionReason>Intra-Community supply to Germany, VAT reverse charge applies. Customer's VAT ID: DE876543210.</cbc:TaxExemptionReason>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <!-- Legal Monetary Total -->
    <cac:LegalMonetaryTotal>
        <!-- Sum of all line net amounts -->
        <cbc:LineExtensionAmount currencyID="DKK">3000</cbc:LineExtensionAmount>
        <!-- Tax exclusive amount -->
        <cbc:TaxExclusiveAmount currencyID="DKK">3000</cbc:TaxExclusiveAmount>
        <!-- Tax inclusive total -->
        <cbc:TaxInclusiveAmount currencyID="DKK">3375</cbc:TaxInclusiveAmount>
        <!-- Total header allowances -->
        <cbc:AllowanceTotalAmount currencyID="DKK">150</cbc:AllowanceTotalAmount>
        <!-- Total header charges -->
        <cbc:ChargeTotalAmount currencyID="DKK">150</cbc:ChargeTotalAmount>
        <!-- Amount due for payment -->
        <cbc:PayableAmount currencyID="DKK">3375</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- Invoice Line 1: Standard 25% MOMS -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="C62">20</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="DKK">1500</cbc:LineExtensionAmount>
        <cac:Item>
            <cbc:Name>Elektronikkomponent / Electronic Component</cbc:Name>
            <cac:OriginCountry>
                <cbc:IdentificationCode>DK</cbc:IdentificationCode>
            </cac:OriginCountry>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>25</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="DKK">75</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

    <!-- Invoice Line 2: Intra-community supply K at 0% -->
    <cac:InvoiceLine>
        <cbc:ID>2</cbc:ID>
        <cbc:InvoicedQuantity unitCode="C62">10</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="DKK">1500</cbc:LineExtensionAmount>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReasonCode>100</cbc:AllowanceChargeReasonCode>
            <cbc:AllowanceChargeReason>Linjerabat / Line discount</cbc:AllowanceChargeReason>
            <cbc:MultiplierFactorNumeric>5</cbc:MultiplierFactorNumeric>
            <cbc:Amount currencyID="DKK">75</cbc:Amount>
            <cbc:BaseAmount currencyID="DKK">1500</cbc:BaseAmount>
        </cac:AllowanceCharge>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReasonCode>ADE</cbc:AllowanceChargeReasonCode>
            <cbc:AllowanceChargeReason>Linjetillæg / Line charge</cbc:AllowanceChargeReason>
            <cbc:MultiplierFactorNumeric>5</cbc:MultiplierFactorNumeric>
            <cbc:Amount currencyID="DKK">75</cbc:Amount>
            <cbc:BaseAmount currencyID="DKK">1500</cbc:BaseAmount>
        </cac:AllowanceCharge>
        <cac:Item>
            <cbc:Description>Industrimaskine til EU-eksport</cbc:Description>
            <cbc:Name>Industrimaskin / Industrial Machine for EU Export</cbc:Name>
            <cac:OriginCountry>
                <cbc:IdentificationCode>DK</cbc:IdentificationCode>
            </cac:OriginCountry>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>K</cbc:ID>
                <cbc:Percent>0</cbc:Percent>
                <cbc:TaxExemptionReasonCode>VATEX-EU-IC</cbc:TaxExemptionReasonCode>
                <cbc:TaxExemptionReason>Intra-Community supply to Germany, VAT reverse charge applies. Customer's VAT ID: DE876543210.</cbc:TaxExemptionReason>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="DKK">150</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>
