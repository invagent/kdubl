<?xml version="1.0" encoding="UTF-8"?>
<!-- KSA (Saudi Arabia) Phase2 Standard Tax Invoice - KDUBL format -->
<!-- InvoiceTypeCode 388 with SubInvoiceTypeCode 0100000 -->
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
         xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
         xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2"
         xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
         xmlns:kdubl="urn:piaozone:ExtensionComponent:1.0">

    <ext:UBLExtensions>
        <ext:UBLExtension>
            <ext:ExtensionAgencyName>Piaozone</ext:ExtensionAgencyName>
            <ext:ExtensionContent>
                <kdubl:PiaozoneExtension>
                    <kdubl:LineExtensions>
                        <kdubl:LineExtension>
                            <kdubl:LineID>1</kdubl:LineID>
                            <!-- KSA-12: TaxInclusiveLineExtensionAmount = LineExtensionAmount(100) + TaxTotal/TaxAmount(15) -->
                            <kdubl:TaxInclusiveLineExtensionAmount currencyID="SAR">115.00</kdubl:TaxInclusiveLineExtensionAmount>
                            <kdubl:TaxExtensions>
                                <kdubl:TaxExtension>
                                    <kdubl:TaxIndex>1</kdubl:TaxIndex>
                                    <kdubl:InternalTaxCode>SA_VAT_S</kdubl:InternalTaxCode>
                                </kdubl:TaxExtension>
                            </kdubl:TaxExtensions>
                        </kdubl:LineExtension>
                        <kdubl:LineExtension>
                            <kdubl:LineID>2</kdubl:LineID>
                            <!-- KSA-12: TaxInclusiveLineExtensionAmount = LineExtensionAmount(100) + TaxTotal/TaxAmount(0) -->
                            <kdubl:TaxInclusiveLineExtensionAmount currencyID="SAR">100.00</kdubl:TaxInclusiveLineExtensionAmount>
                            <kdubl:TaxExtensions>
                                <kdubl:TaxExtension>
                                    <kdubl:TaxIndex>1</kdubl:TaxIndex>
                                    <kdubl:InternalTaxCode>SA_VAT_E</kdubl:InternalTaxCode>
                                </kdubl:TaxExtension>
                            </kdubl:TaxExtensions>
                        </kdubl:LineExtension>
                    </kdubl:LineExtensions>
                </kdubl:PiaozoneExtension>
            </ext:ExtensionContent>
        </ext:UBLExtension>
    </ext:UBLExtensions>

    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
    <cbc:CustomizationID>urn:piaozone.com:ubl-2.1-customizations:v1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:piaozone.com:profile:bill:v1.0</cbc:ProfileID>

    <!-- BT-1 Invoice Number (IRN) -->
    <cbc:ID>SA-INV-2026-001</cbc:ID>
    <!-- BT-2 Invoice Issue Date -->
    <cbc:IssueDate>2026-02-26</cbc:IssueDate>
    <!-- Invoice Issue Time (KSA requires time) -->
    <cbc:IssueTime>09:00:00+03:00</cbc:IssueTime>
    <!-- BT-9 Due Date -->
    <cbc:DueDate>2026-03-26</cbc:DueDate>
    <!-- BT-3 Invoice Type Code: 388 = Standard Tax Invoice -->
    <cbc:InvoiceTypeCode>388</cbc:InvoiceTypeCode>
    <!-- BT-5 Document Currency Code -->
    <cbc:DocumentCurrencyCode>SAR</cbc:DocumentCurrencyCode>
    <!-- BT-10 Buyer Reference (required by PEPPOL EN16931) -->
    <cbc:BuyerReference>SA-REF-001</cbc:BuyerReference>

    <!-- KSA-2 Transaction Code (SubInvoiceTypeCode): 0100000 = standard B2B tax invoice -->
    <cac:AdditionalDocumentReference>
        <cbc:ID schemeName="InvoiceTag">0100000</cbc:ID>
        <cbc:DocumentType>SubInvoiceTypeCode</cbc:DocumentType>
    </cac:AdditionalDocumentReference>

    <cac:AdditionalDocumentReference>
        <cbc:ID schemeName="InvoiceTag">quanchun_lei@kingdee.com</cbc:ID>
        <cbc:DocumentType>SenderEmail</cbc:DocumentType>
    </cac:AdditionalDocumentReference>

    <!-- Seller/Supplier Information -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <!-- BT-29 SA Seller Party ID: CRN (Commercial Registration Number) -->
            <cac:PartyIdentification>
                <cbc:ID schemeID="SA:CRN">12222222</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyName>
                <cbc:Name>Supplier Registration Name</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <!-- BT-35 Seller address street -->
                <cbc:StreetName>Street Name</cbc:StreetName>
                <!-- KSA-17 Seller address building number -->
                <cbc:BuildingNumber>1234</cbc:BuildingNumber>
                <!-- KSA-23 Seller address additional number (plot identification) -->
                <cbc:PlotIdentification>0000</cbc:PlotIdentification>
                <!-- KSA-3 Seller district (city subdivision) -->
                <cbc:CitySubdivisionName>District</cbc:CitySubdivisionName>
                <!-- BT-37 Seller address city -->
                <cbc:CityName>City</cbc:CityName>
                <!-- BT-38 Seller address postal code -->
                <cbc:PostalZone>00000</cbc:PostalZone>
                <!-- BT-39 Seller address province/state -->
                <cbc:CountrySubentity>Province</cbc:CountrySubentity>
                <cac:Country>
                    <!-- BT-40 Seller address country code -->
                    <cbc:IdentificationCode>SA</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <!-- BT-31 Seller VAT Number -->
                <cbc:CompanyID>SA313144092200003</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <!-- BT-27 Seller Name -->
                <cbc:RegistrationName>Supplier Registration Name</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- Buyer/Customer Information -->
    <cac:AccountingCustomerParty>
        <cbc:SupplierAssignedAccountID>Customer Number</cbc:SupplierAssignedAccountID>
        <cac:Party>
            <!-- BT-46 SA Buyer Party ID: OTH (Other identifier) -->
            <cac:PartyIdentification>
                <cbc:ID schemeID="SA:OTH">123456</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyName>
                <cbc:Name>Buyer Name</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <!-- BT-50 Buyer address street -->
                <cbc:StreetName>Street Name</cbc:StreetName>
                <!-- KSA-18 Buyer address building number -->
                <cbc:BuildingNumber>1234</cbc:BuildingNumber>
                <!-- KSA-19 Buyer address additional number (plot identification) -->
                <cbc:PlotIdentification>0000</cbc:PlotIdentification>
                <!-- KSA-4 Buyer district (city subdivision) -->
                <cbc:CitySubdivisionName>District</cbc:CitySubdivisionName>
                <!-- BT-52 Buyer address city -->
                <cbc:CityName>City</cbc:CityName>
                <!-- BT-53 Buyer address postal code -->
                <cbc:PostalZone>00000</cbc:PostalZone>
                <!-- BT-54 Buyer address province/state -->
                <cbc:CountrySubentity>Province</cbc:CountrySubentity>
                <cac:Country>
                    <!-- BT-55 Buyer address country code -->
                    <cbc:IdentificationCode>SA</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <!-- BT-48 Buyer VAT Number -->
                <cbc:CompanyID>SA32xxxxxxxx00003</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <!-- BT-44 Buyer Name -->
                <cbc:RegistrationName>Buyer Name</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- KSA-5 Supply Date -->
    <cac:Delivery>
        <cbc:ActualDeliveryDate>2026-02-26</cbc:ActualDeliveryDate>
    </cac:Delivery>

    <cac:PaymentMeans>
        <!-- BT-81 Payment means code. Valid values in KSA: 10, 30, 42, 48, 1 -->
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode>
        <cac:PayeeFinancialAccount>
            <!-- BT-84 Financial account identifier -->
            <cbc:ID>SA1234567891234567891</cbc:ID>
            <cac:FinancialInstitutionBranch>
                <!-- BT-86 Payment service provider identifier -->
                <cbc:ID>SWIFTCODE</cbc:ID>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>

    <!-- BG-20 Document level allowance (discount) -->
    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
        <cbc:AllowanceChargeReason>Discount</cbc:AllowanceChargeReason>
        <cbc:Amount currencyID="SAR">5.00</cbc:Amount>
        <cac:TaxCategory>
            <cbc:ID>E</cbc:ID>
            <cbc:Percent>0</cbc:Percent>
            <cac:TaxScheme>
                <cbc:ID>VAT</cbc:ID>
            </cac:TaxScheme>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <!-- BT-110 Invoice total VAT amount -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="SAR">15.00</cbc:TaxAmount>
        <!-- Standard taxed subtotal (S category) -->
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="SAR">100.00</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="SAR">15.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>15.00</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
        <!-- Exempt subtotal (E category) with ZATCA exemption reason code -->
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="SAR">95.00</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="SAR">0.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <cbc:ID>E</cbc:ID>
                <cbc:Percent>0</cbc:Percent>
                <!-- BT-121 VAT exemption reason code (ZATCA specific codes) -->
                <cbc:TaxExemptionReasonCode>VATEX-SA-29-7</cbc:TaxExemptionReasonCode>
                <!-- BT-120 VAT exemption reason text -->
                <cbc:TaxExemptionReason>Life insurance services mentioned in Article 29 of the VAT Regulations</cbc:TaxExemptionReason>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <!-- Invoice Total Amounts -->
    <cac:LegalMonetaryTotal>
        <cbc:LineExtensionAmount currencyID="SAR">200.00</cbc:LineExtensionAmount>
        <cbc:TaxExclusiveAmount currencyID="SAR">195.00</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="SAR">210.00</cbc:TaxInclusiveAmount>
        <cbc:AllowanceTotalAmount currencyID="SAR">5.00</cbc:AllowanceTotalAmount>
        <cbc:PayableAmount currencyID="SAR">210.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- Invoice Line 1: Standard taxed article (S category, 15%) -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="EA">1</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="SAR">100.00</cbc:LineExtensionAmount>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReason>Discount</cbc:AllowanceChargeReason>
            <cbc:Amount currencyID="SAR">10</cbc:Amount>
        </cac:AllowanceCharge>
        <!-- KSA-11 Line VAT Amount -->
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="SAR">15.00</cbc:TaxAmount>
        </cac:TaxTotal>
        <cac:Item>
            <cbc:Name>Article 1</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <!-- BT-151 with schemeID="UNCL5305" as required by KSA -->
                <cbc:ID schemeID="UNCL5305">S</cbc:ID>
                <!-- BT-152 VAT rate -->
                <cbc:Percent>15</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="SAR">110.00</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

    <!-- Invoice Line 2: Exempt article (E category, 0%) -->
    <cac:InvoiceLine>
        <cbc:ID>2</cbc:ID>
        <cbc:InvoicedQuantity unitCode="EA">1</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="SAR">100.00</cbc:LineExtensionAmount>
        <!-- KSA-11 Line VAT Amount (0 for exempt) -->
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="SAR">0.00</cbc:TaxAmount>
        </cac:TaxTotal>
        <cac:Item>
            <cbc:Name>Article 2</cbc:Name>
            <cac:ClassifiedTaxCategory>
                <cbc:ID schemeID="UNCL5305">E</cbc:ID>
                <cbc:Percent>0</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="SAR">100.00</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>
