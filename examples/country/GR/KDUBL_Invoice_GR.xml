<?xml version="1.0" encoding="UTF-8"?>
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
         xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
         xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

    <!-- Greece (GR) KDUBL Invoice Sample -->
    <!-- Greek VAT (ΦΠΑ - Φόρος Προστιθέμενης Αξίας) standard rate: 24% -->
    <!-- Intra-community supply to EU buyer: K category (zero-rated) -->
    <!-- Currency: EUR (Greece uses Euro) -->
    <!-- Note: Greece VAT prefix is "GR" (ISO) or "EL" (legacy). UBL-COMMON checks both. -->

    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
    <cbc:CustomizationID>urn:piaozone.com:ubl-2.1-customizations:v1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:piaozone.com:profile:bill:v1.0</cbc:ProfileID>

    <!-- Invoice Number / Αριθμός τιμολογίου -->
    <cbc:ID>GR20260317001001</cbc:ID>
    <!-- Issue Date / Ημερομηνία έκδοσης -->
    <cbc:IssueDate>2026-03-17</cbc:IssueDate>
    <cbc:IssueTime>09:00:00+02:00</cbc:IssueTime>
    <!-- Due Date / Ημερομηνία λήξης -->
    <cbc:DueDate>2026-04-17</cbc:DueDate>
    <!-- Invoice Type: 380 = Commercial invoice -->
    <cbc:InvoiceTypeCode>380</cbc:InvoiceTypeCode>
    <cbc:Note>Τιμολόγιο / Greek VAT Invoice (ΦΠΑ 24%)</cbc:Note>
    <!-- Currency: EUR -->
    <cbc:DocumentCurrencyCode>EUR</cbc:DocumentCurrencyCode>
    <!-- Buyer Reference / Αναφορά αγοραστή -->
    <cbc:BuyerReference>GR-BUYER-REF-001</cbc:BuyerReference>

    <!-- Invoice Period / Περίοδος τιμολογίου -->
    <cac:InvoicePeriod>
        <cbc:StartDate>2026-03-01</cbc:StartDate>
        <cbc:EndDate>2026-03-31</cbc:EndDate>
    </cac:InvoicePeriod>

    <!-- Order Reference / Αναφορά παραγγελίας -->
    <cac:OrderReference>
        <cbc:ID>GR-ORDER-20260301</cbc:ID>
    </cac:OrderReference>

    <!-- InvoiceContext -->
    <cac:AdditionalDocumentReference>
        <cbc:ID schemeName="InvoiceTag">NA</cbc:ID>
        <cbc:DocumentType>InvoiceContext</cbc:DocumentType>
    </cac:AdditionalDocumentReference>

    <!-- SelfBilled -->
    <cac:AdditionalDocumentReference>
        <cbc:ID schemeName="InvoiceTag">false</cbc:ID>
        <cbc:DocumentType>SelfBilled</cbc:DocumentType>
    </cac:AdditionalDocumentReference>

    <!-- Attachment / Συνημμένο -->
    <cac:AdditionalDocumentReference>
        <cbc:ID>GR-DOC-001</cbc:ID>
        <cbc:DocumentDescription>Ανάλυση τιμολογίου / Invoice breakdown</cbc:DocumentDescription>
        <cac:Attachment>
            <cac:ExternalReference>
                <cbc:URI>https://www.example.gr/timologio/spec001.html</cbc:URI>
            </cac:ExternalReference>
        </cac:Attachment>
    </cac:AdditionalDocumentReference>

    <!-- Supplier (Seller) / Πωλητής -->
    <cac:AccountingSupplierParty>
        <cac:Party>
            <cac:PartyName>
                <cbc:Name>Kingdee Hellas A.E.</cbc:Name>
            </cac:PartyName>
            <!-- Supplier Address / Διεύθυνση προμηθευτή -->
            <cac:PostalAddress>
                <cbc:StreetName>Λεωφόρος Αθηνών 100</cbc:StreetName>
                <cbc:AdditionalStreetName>3ος όροφος</cbc:AdditionalStreetName>
                <cbc:CityName>Αθήνα</cbc:CityName>
                <cbc:PostalZone>10431</cbc:PostalZone>
                <cbc:CountrySubentity>Αττική</cbc:CountrySubentity>
                <cac:Country>
                    <cbc:IdentificationCode>GR</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <!-- Greek VAT number (ΑΦΜ): GR + 9 digits -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>GR123456789</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <!-- ΓΕΜΗ: General Commercial Registry number -->
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Kingdee Hellas A.E.</cbc:RegistrationName>
                <cbc:CompanyID schemeID="GR:GEMI">123456789000</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Νίκος Παπαδόπουλος</cbc:Name>
                <cbc:Telephone>+30-210-123-4567</cbc:Telephone>
                <cbc:ElectronicMail>nikos.papadopoulos@kingdee.gr</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- Buyer (Customer) / Αγοραστής (EU buyer for intra-community supply) -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <cac:PartyName>
                <cbc:Name>European Buyer GmbH</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:StreetName>Σταδίου 25</cbc:StreetName>
                <cbc:AdditionalStreetName>2ος όροφος</cbc:AdditionalStreetName>
                <cbc:CityName>Θεσσαλονίκη</cbc:CityName>
                <cbc:PostalZone>54621</cbc:PostalZone>
                <cbc:CountrySubentity>Κεντρική Μακεδονία</cbc:CountrySubentity>
                <cac:Country>
                    <cbc:IdentificationCode>DE</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <!-- German buyer VAT number for intra-community supply -->
            <cac:PartyTaxScheme>
                <cbc:CompanyID>DE876543210</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>European Buyer GmbH</cbc:RegistrationName>
                <cbc:CompanyID schemeID="DE:STNR">DE876543210</cbc:CompanyID>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Name>Μαρία Κωνσταντίνου</cbc:Name>
                <cbc:Telephone>+30-2310-987-654</cbc:Telephone>
                <cbc:ElectronicMail>maria.konstantinou@eubuyer.de</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- Delivery / Παράδοση -->
    <cac:Delivery>
        <cbc:ActualDeliveryDate>2026-03-15</cbc:ActualDeliveryDate>
        <cac:DeliveryLocation>
            <cac:Address>
                <cbc:StreetName>Βασιλέως Κωνσταντίνου 10</cbc:StreetName>
                <cbc:CityName>Πάτρα</cbc:CityName>
                <cbc:PostalZone>26221</cbc:PostalZone>
                <cac:Country>
                    <cbc:IdentificationCode>DE</cbc:IdentificationCode>
                </cac:Country>
            </cac:Address>
        </cac:DeliveryLocation>
    </cac:Delivery>

    <!-- Payment Means / Τρόπος πληρωμής -->
    <cac:PaymentMeans>
        <cbc:PaymentMeansCode>30</cbc:PaymentMeansCode> <!-- Bank Transfer -->
        <cac:PayeeFinancialAccount>
            <cbc:ID>GR1601101250000000012300695</cbc:ID>
            <cbc:Name>Kingdee Hellas A.E.</cbc:Name>
            <cac:FinancialInstitutionBranch>
                <cbc:ID>ETHNGRAA</cbc:ID>
                <cac:FinancialInstitution>
                    <cbc:Name>Εθνική Τράπεζα της Ελλάδος / National Bank of Greece</cbc:Name>
                </cac:FinancialInstitution>
            </cac:FinancialInstitutionBranch>
        </cac:PayeeFinancialAccount>
    </cac:PaymentMeans>

    <!-- Payment Terms / Όροι πληρωμής -->
    <cac:PaymentTerms>
        <cbc:Note>Πληρωμή εντός 30 ημερών / Net 30 days from invoice date</cbc:Note>
    </cac:PaymentTerms>

    <!-- Header Charge / Χρέωση κεφαλίδας (Standard rate 24% ΦΠΑ) -->
    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
        <cbc:AllowanceChargeReasonCode>CG</cbc:AllowanceChargeReasonCode>
        <cbc:AllowanceChargeReason>Χρέωση διαχείρισης / Handling charge</cbc:AllowanceChargeReason>
        <cbc:MultiplierFactorNumeric>10</cbc:MultiplierFactorNumeric>
        <cbc:Amount currencyID="EUR">20.00</cbc:Amount>
        <cbc:BaseAmount currencyID="EUR">200.00</cbc:BaseAmount>
        <cac:TaxCategory>
            <cbc:ID>S</cbc:ID>
            <cbc:Percent>24</cbc:Percent>
            <cac:TaxScheme>
                <cbc:ID>VAT</cbc:ID>
            </cac:TaxScheme>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <!-- Header Discount / Έκπτωση κεφαλίδας -->
    <cac:AllowanceCharge>
        <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
        <cbc:AllowanceChargeReasonCode>100</cbc:AllowanceChargeReasonCode>
        <cbc:AllowanceChargeReason>Έκπτωση / Discount</cbc:AllowanceChargeReason>
        <cbc:Amount currencyID="EUR">20.00</cbc:Amount>
        <cac:TaxCategory>
            <cbc:ID>S</cbc:ID>
            <cbc:Percent>24</cbc:Percent>
            <cac:TaxScheme>
                <cbc:ID>VAT</cbc:ID>
            </cac:TaxScheme>
        </cac:TaxCategory>
    </cac:AllowanceCharge>

    <!-- Tax Total / Σύνολο ΦΠΑ -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="EUR">24.00</cbc:TaxAmount> <!-- BT-110 -->
        <!-- Standard rate 24% ΦΠΑ -->
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="EUR">100.00</cbc:TaxableAmount> <!-- BT-116 -->
            <cbc:TaxAmount currencyID="EUR">24.00</cbc:TaxAmount> <!-- BT-117 -->
            <cac:TaxCategory>
                <cbc:ID>S</cbc:ID> <!-- BT-118 Standard rated -->
                <cbc:Percent>24</cbc:Percent> <!-- BT-119 Greek VAT standard rate -->
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
        <!-- Intra-community supply K at 0% -->
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="EUR">100.00</cbc:TaxableAmount> <!-- BT-116 -->
            <cbc:TaxAmount currencyID="EUR">0.00</cbc:TaxAmount> <!-- BT-117 -->
            <cac:TaxCategory>
                <cbc:ID>K</cbc:ID> <!-- BT-118 Intra-community supply -->
                <cbc:Percent>0</cbc:Percent> <!-- BT-119 -->
                <cbc:TaxExemptionReasonCode>VATEX-EU-IC</cbc:TaxExemptionReasonCode>
                <cbc:TaxExemptionReason>Intra-Community supply to Germany, VAT reverse charge applies. Customer's VAT ID: DE876543210.</cbc:TaxExemptionReason>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <!-- Legal Monetary Total / Νομικό σύνολο -->
    <cac:LegalMonetaryTotal>
        <cbc:LineExtensionAmount currencyID="EUR">200.00</cbc:LineExtensionAmount>
        <cbc:TaxExclusiveAmount currencyID="EUR">200.00</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="EUR">224.00</cbc:TaxInclusiveAmount>
        <cbc:AllowanceTotalAmount currencyID="EUR">20.00</cbc:AllowanceTotalAmount>
        <cbc:ChargeTotalAmount currencyID="EUR">20.00</cbc:ChargeTotalAmount>
        <cbc:PayableAmount currencyID="EUR">224.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- Invoice Line 1: Standard 24% ΦΠΑ -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="C62">20</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="EUR">100.00</cbc:LineExtensionAmount>
        <cac:Item>
            <cbc:Name>Ηλεκτρονικά εξαρτήματα / Electronic Components</cbc:Name>
            <cac:OriginCountry>
                <cbc:IdentificationCode>GR</cbc:IdentificationCode>
            </cac:OriginCountry>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>S</cbc:ID>
                <cbc:Percent>24</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="EUR">5.00</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

    <!-- Invoice Line 2: Intra-community supply K at 0% -->
    <cac:InvoiceLine>
        <cbc:ID>2</cbc:ID>
        <cbc:InvoicedQuantity unitCode="C62">10</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="EUR">100.00</cbc:LineExtensionAmount>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReasonCode>100</cbc:AllowanceChargeReasonCode>
            <cbc:AllowanceChargeReason>Έκπτωση γραμμής / Line discount</cbc:AllowanceChargeReason>
            <cbc:MultiplierFactorNumeric>5</cbc:MultiplierFactorNumeric>
            <cbc:Amount currencyID="EUR">5.00</cbc:Amount>
            <cbc:BaseAmount currencyID="EUR">100.00</cbc:BaseAmount>
        </cac:AllowanceCharge>
        <cac:AllowanceCharge>
            <cbc:ChargeIndicator>true</cbc:ChargeIndicator>
            <cbc:AllowanceChargeReasonCode>ADE</cbc:AllowanceChargeReasonCode>
            <cbc:AllowanceChargeReason>Χρέωση γραμμής / Line charge</cbc:AllowanceChargeReason>
            <cbc:MultiplierFactorNumeric>5</cbc:MultiplierFactorNumeric>
            <cbc:Amount currencyID="EUR">5.00</cbc:Amount>
            <cbc:BaseAmount currencyID="EUR">100.00</cbc:BaseAmount>
        </cac:AllowanceCharge>
        <cac:Item>
            <cbc:Description>Βιομηχανικός εξοπλισμός για ενδοκοινοτική παράδοση</cbc:Description>
            <cbc:Name>Βιομηχανικές μηχανές / Industrial Machines for EU Export</cbc:Name>
            <cac:OriginCountry>
                <cbc:IdentificationCode>GR</cbc:IdentificationCode>
            </cac:OriginCountry>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>K</cbc:ID>
                <cbc:Percent>0</cbc:Percent>
                <cbc:TaxExemptionReasonCode>VATEX-EU-IC</cbc:TaxExemptionReasonCode>
                <cbc:TaxExemptionReason>Intra-Community supply to Germany, VAT reverse charge applies. Customer's VAT ID: DE876543210.</cbc:TaxExemptionReason>
                <cac:TaxScheme>
                    <cbc:ID>VAT</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="EUR">10.00</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>

</Invoice>
