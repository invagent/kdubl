      TaxableAmount = cumulative room-nights (3 nights, as quantity base)
      TaxAmount = 3 nights × 10.00 MYR = 30.00
      cbc:Percent is omitted (fixed rate, not percentage-based)
    -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="MYR">30.00</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <!-- TaxableAmount here represents the quantity base (3 room-nights) -->
            <cbc:TaxableAmount currencyID="MYR">3</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="MYR">30.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <cbc:ID>03</cbc:ID>
                <!-- No cbc:Percent for fixed rate — PRD 3.4 机制B -->
                <cac:TaxScheme>
                    <cbc:ID>SST</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

