<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!--
  CONSOLIDATED TARGET - Normal Direction, Fixed Rate Tax (固定税额合并)
  PRD Section 3.4 机制B: Fixed Rate tax (Tourism Tax 10 MYR/room/night)
  Sources: RCP-2026-005 (3 nights, 450.00 room charge) + RCP-2026-006 (2 nights, 300.00 room charge)
  Supplier: Hotel Grand KL Sdn Bhd (TIN C5555555555)
  Merge totals:
    lineExtensionAmount = 450+300 = 750.00
    total room-nights (quantity base) = 3+2 = 5
    taxAmount = 5 × 10 MYR = 50.00
    taxInclusiveAmount = 800.00
  PRD 3.4 机制B: TaxableAmount = cumulative quantity (5), cbc:Percent omitted
  PRD 3.2: Supplier = Hotel Grand KL (from source), Customer = General Public
-->
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
    xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
    xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

    <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
    <cbc:CustomizationID>urn:piaozone.com:ubl-2.1-customizations:v1.0</cbc:CustomizationID>
    <cbc:ProfileID>urn:piaozone.com:profile:bill:v1.0</cbc:ProfileID>
    <cbc:ID>REPORT_CON_2026060004</cbc:ID>
    <cbc:IssueDate>2026-06-07</cbc:IssueDate>
    <cbc:IssueTime>10:18:00+08:00</cbc:IssueTime>
    <cbc:InvoiceTypeCode listVersionID="1.0">01</cbc:InvoiceTypeCode>
    <cbc:DocumentCurrencyCode>MYR</cbc:DocumentCurrencyCode>

    <cac:AccountingSupplierParty>
        <cac:Party>
            <cbc:IndustryClassificationCode name="HOTELS AND SIMILAR ACCOMMODATION">55100</cbc:IndustryClassificationCode>
            <cac:PartyIdentification>
                <cbc:ID schemeID="TIN">C5555555555</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyIdentification>
                <cbc:ID schemeID="BRN">200001045678</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyIdentification>
                <cbc:ID schemeID="SST">W16-1812-32100045</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyName>
                <cbc:Name>Hotel Grand KL Sdn Bhd</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:StreetName>50, Jalan Sultan Ismail</cbc:StreetName>
                <cbc:CityName>Kuala Lumpur</cbc:CityName>
                <cbc:PostalZone>50250</cbc:PostalZone>
                <cbc:CountrySubentityCode>14</cbc:CountrySubentityCode>
                <cac:Country>
                    <cbc:IdentificationCode>MYS</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <cbc:CompanyID>W16-1812-32100045</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>SST</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>Hotel Grand KL Sdn Bhd</cbc:RegistrationName>
            </cac:PartyLegalEntity>
            <cac:Contact>
                <cbc:Telephone>+60321112222</cbc:Telephone>
                <cbc:ElectronicMail>finance@hotelgrandkl.com.my</cbc:ElectronicMail>
            </cac:Contact>
        </cac:Party>
    </cac:AccountingSupplierParty>

    <!-- PRD 3.2 正向开票: Customer anonymized to General Public -->
    <cac:AccountingCustomerParty>
        <cac:Party>
            <cac:PartyIdentification>
                <cbc:ID schemeID="TIN">EI00000000010</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyIdentification>
                <cbc:ID schemeID="BRN">NA</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyName>
                <cbc:Name>General Public</cbc:Name>
            </cac:PartyName>
            <cac:PostalAddress>
                <cbc:PostalZone>NA</cbc:PostalZone>
                <cac:AddressLine>
                    <cbc:Line>NA</cbc:Line>
                </cac:AddressLine>
                <cac:Country>
                    <cbc:IdentificationCode>MYS</cbc:IdentificationCode>
                </cac:Country>
            </cac:PostalAddress>
            <cac:PartyTaxScheme>
                <cbc:CompanyID>NA</cbc:CompanyID>
                <cac:TaxScheme>
                    <cbc:ID>SST</cbc:ID>
                </cac:TaxScheme>
            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>General Public</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!--
      PRD 3.4 机制B: Fixed Rate tax
      TaxableAmount = cumulative quantity base (5 room-nights total)
      TaxAmount = 5 × 10.00 = 50.00
      cbc:Percent is omitted — fixed rate, not percentage
    -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="MYR">50.00</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <!-- Quantity base: 3 + 2 = 5 room-nights -->
            <cbc:TaxableAmount currencyID="MYR">5</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="MYR">50.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <cbc:ID>03</cbc:ID>
                <!-- cbc:Percent omitted per PRD 3.4 机制B -->
                <cac:TaxScheme>
                    <cbc:ID>SST</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <cac:LegalMonetaryTotal>
        <cbc:LineExtensionAmount currencyID="MYR">750.00</cbc:LineExtensionAmount>
        <cbc:TaxExclusiveAmount currencyID="MYR">750.00</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="MYR">800.00</cbc:TaxInclusiveAmount>
        <cbc:AllowanceTotalAmount currencyID="MYR">0.00</cbc:AllowanceTotalAmount>
        <cbc:ChargeTotalAmount currencyID="MYR">0.00</cbc:ChargeTotalAmount>
        <cbc:PrepaidAmount currencyID="MYR">0.00</cbc:PrepaidAmount>
        <cbc:PayableRoundingAmount currencyID="MYR">0.00</cbc:PayableRoundingAmount>
        <cbc:PayableAmount currencyID="MYR">800.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!--
      PRD 3.3 选项一 情况A: Single tax bucket (03/SST fixed) → one compressed invoiceLine
      description = "Summary of Receipt #RCP-2026-005 to RCP-2026-006 (SST 03 Fixed 10MYR/night)"
      lineExtensionAmount = 450.00 + 300.00 = 750.00
    -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <!-- Total room-nights across both receipts -->
        <cbc:InvoicedQuantity unitCode="NIght">5</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="MYR">750.00</cbc:LineExtensionAmount>
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="MYR">50.00</cbc:TaxAmount>
            <cac:TaxSubtotal>
                <cbc:TaxableAmount currencyID="MYR">5</cbc:TaxableAmount>
                <cbc:TaxAmount currencyID="MYR">50.00</cbc:TaxAmount>
                <cac:TaxCategory>
                    <cbc:ID>03</cbc:ID>
                    <cac:TaxScheme>
                        <cbc:ID>SST</cbc:ID>
                    </cac:TaxScheme>
                </cac:TaxCategory>
            </cac:TaxSubtotal>
        </cac:TaxTotal>
        <cac:Item>
            <cbc:Description>Summary of Receipt #RCP-2026-005 to RCP-2026-006 (SST 03 Fixed 10MYR/night)</cbc:Description>
            <cbc:Name>Consolidated Receipts</cbc:Name>
            <cac:CommodityClassification>
                <cbc:ItemClassificationCode listID="CLASS">004</cbc:ItemClassificationCode>
            </cac:CommodityClassification>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>03</cbc:ID>
                <!-- No Percent for fixed rate -->
                <cac:TaxScheme>
                    <cbc:ID>SST</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="MYR">150.00</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>
</Invoice>
