<!--
  CONSOLIDATED TARGET - Normal Direction, Single Tax Rate (详细汇总模式)
  PRD Section 3.3 选项一 情况A: All receipts same tax bucket → one invoiceLine
  Sources: RCP-2026-001 (320.00) + RCP-2026-002 (180.00) + RCP-2026-003 (220.00)
  All SST 01 @ 10%
  Merge totals:
    lineExtensionAmount = 320+180+220 = 720.00
    taxAmount = 32+18+22 = 72.00 (= 720.00 × 10%)
    taxInclusiveAmount = 792.00
  PRD 3.2: Supplier = Kedai Makan (from source), Customer = General Public
  PRD 3.5: IssueDate/Time = execution timestamp UTC+8
-->
<Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
    xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
    xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">

