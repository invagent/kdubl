        <cbc:PayableAmount currencyID="MYR">792.00</cbc:PayableAmount>
    </cac:LegalMonetaryTotal>

    <!-- PRD 3.3 选项一 情况A: Single tax bucket → one compressed invoiceLine -->
    <cac:InvoiceLine>
        <cbc:ID>1</cbc:ID>
        <cbc:InvoicedQuantity unitCode="EA">1</cbc:InvoicedQuantity>
        <cbc:LineExtensionAmount currencyID="MYR">720.00</cbc:LineExtensionAmount>
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="MYR">72.00</cbc:TaxAmount>
            <cac:TaxSubtotal>
                <cbc:TaxableAmount currencyID="MYR">720.00</cbc:TaxableAmount>
                <cbc:TaxAmount currencyID="MYR">72.00</cbc:TaxAmount>
                <cac:TaxCategory>
                    <cbc:ID>01</cbc:ID>
                    <cbc:Percent>10</cbc:Percent>
                    <cac:TaxScheme>
                        <cbc:ID>SST</cbc:ID>
                    </cac:TaxScheme>
                </cac:TaxCategory>
            </cac:TaxSubtotal>
        </cac:TaxTotal>
        <cac:Item>
            <cbc:Description>Summary of Receipt #RCP-2026-001 to RCP-2026-003 (SST 01 10%)</cbc:Description>
            <cbc:Name>Consolidated Receipts</cbc:Name>
            <cac:CommodityClassification>
                <cbc:ItemClassificationCode listID="CLASS">004</cbc:ItemClassificationCode>
            </cac:CommodityClassification>
            <cac:ClassifiedTaxCategory>
                <cbc:ID>01</cbc:ID>
                <cbc:Percent>10</cbc:Percent>
                <cac:TaxScheme>
                    <cbc:ID>SST</cbc:ID>
                </cac:TaxScheme>
            </cac:ClassifiedTaxCategory>
        </cac:Item>
        <cac:Price>
            <cbc:PriceAmount currencyID="MYR">720.00</cbc:PriceAmount>
        </cac:Price>
    </cac:InvoiceLine>
</Invoice>
