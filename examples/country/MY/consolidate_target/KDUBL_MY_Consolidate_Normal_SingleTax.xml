                    <cbc:ID>SST</cbc:ID>
                </cac:TaxScheme>
            </cac:TaxCategory>
        </cac:TaxSubtotal>
    </cac:TaxTotal>

    <cac:LegalMonetaryTotal>
        <cbc:LineExtensionAmount currencyID="MYR">720.00</cbc:LineExtensionAmount>
        <cbc:TaxExclusiveAmount currencyID="MYR">720.00</cbc:TaxExclusiveAmount>
        <cbc:TaxInclusiveAmount currencyID="MYR">792.00</cbc:TaxInclusiveAmount>
        <cbc:AllowanceTotalAmount currencyID="MYR">0.00</cbc:AllowanceTotalAmount>
        <cbc:ChargeTotalAmount currencyID="MYR">0.00</cbc:ChargeTotalAmount>
