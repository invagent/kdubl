            </cac:PartyTaxScheme>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName>General Public</cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingCustomerParty>

    <!-- PRD 3.4 机制A: 720.00 × 10% = 72.00 -->
    <cac:TaxTotal>
        <cbc:TaxAmount currencyID="MYR">72.00</cbc:TaxAmount>
        <cac:TaxSubtotal>
            <cbc:TaxableAmount currencyID="MYR">720.00</cbc:TaxableAmount>
            <cbc:TaxAmount currencyID="MYR">72.00</cbc:TaxAmount>
            <cac:TaxCategory>
                <cbc:ID>01</cbc:ID>
                <cbc:Percent>10</cbc:Percent>
