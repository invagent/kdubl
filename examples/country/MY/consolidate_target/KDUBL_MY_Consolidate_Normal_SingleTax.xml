    <cbc:ID>REPORT_CON_2026060001</cbc:ID>
    <cbc:IssueDate>2026-06-07</cbc:IssueDate>
    <cbc:IssueTime>10:15:30+08:00</cbc:IssueTime>
    <cbc:InvoiceTypeCode listVersionID="1.0">01</cbc:InvoiceTypeCode>
